---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🎩 {SITE_TITLE}</h1>
			<p>
				Элегантно о рынках. Без воды.
				Order flow, volume profile, макро — конкретные уровни и авторская аналитика.
			</p>

			<h2>Форматы выпусков</h2>
			<ul>
				<li><strong>☕ Утренний</strong> — сводка за ночь, курсы ЦБ, ключевые уровни, фокус дня</li>
				<li><strong>🔥 Вечерний</strong> — разбор дня, главная новость, прогноз на завтра</li>
				<li><strong>📊 Воскресный</strong> — итоги недели, объёмный анализ, сетап, макро</li>
			</ul>

			<p>
				📈 Акции · Фьючерсы · Крипта · Commodities · Forex · Макро
			</p>

			<p>
				<a href="/blog">Читать блог →</a> · <a href="https://t.me/bourse_dandy" target="_blank">Telegram-канал →</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
